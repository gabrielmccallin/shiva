{
    "compilerOptions": {
        "target": "es2020",
        "declarationDir": "dist",
        "declaration": true,
        "module": "es2020",
        "moduleResolution": "node",
        "outDir": "dist",
        "lib": [ "es2020", "dom" ],
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": [ "src/**/*" ],
    "exclude": [ "src/**/*.test.ts", "dist" ]
}
