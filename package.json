{
    "name": "shiva",
    "version": "6.0.1",
    "description": "Minimal JavaScript library for building user interfaces",
    "main": "dist/shiva.js",
    "module": "dist/shiva.js",
    "types": "dist/shiva.d.mts",
    "exports": {
        ".": {
            "import": "./dist/shiva.js",
            "types": "./dist/shiva.d.mts"
        }
    },
    "scripts": {
        "build": "tsup",
        "start": "echo And in all, the creator, preserver, destroyer, revealer and concealer of all that is",
        "test": "jest",
        "test-watch": "jest --watch",
        "prepublishOnly": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/gabrielmccallin/shiva.git"
    },
    "author": "Gabriel McCallin",
    "license": "MIT",
    "devDependencies": {
        "@types/jest": "^29.2.5",
        "jest": "^29.3.1",
        "jest-environment-jsdom": "^30.2.0",
        "ts-jest": "^29.0.5",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "keywords": [
        "declarative",
        "front-end",
        "javascript",
        "library",
        "ui"
    ],
    "sideEffects": false,
    "files": [
        "dist/"
    ]
}
